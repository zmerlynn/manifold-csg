From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Zach Loafman <zml@zml.net>
Subject: [PATCH] Make Manifold and CrossSection safe for concurrent const
 access

Use std::call_once to synchronize lazy evaluation in
Manifold::GetCsgLeafNode() and CrossSection::GetPaths(), preventing
data races when multiple threads call const methods on the same object.

Upstream PR: https://github.com/elalish/manifold/pull/1636
---
diff --git a/include/manifold/cross_section.h b/include/manifold/cross_section.h
index fe13df3..1a1e36b 100644
--- a/include/manifold/cross_section.h
+++ b/include/manifold/cross_section.h
@@ -16,6 +16,7 @@
 
 #include <functional>
 #include <memory>
+#include <mutex>
 #include <vector>
 
 #include "manifold/common.h"
@@ -175,6 +176,8 @@ class CrossSection {
   ///@}
 
  private:
+  mutable std::shared_ptr<std::once_flag> pathsOnce_ =
+      std::make_shared<std::once_flag>();
   mutable std::shared_ptr<const PathImpl> paths_;
   mutable mat2x3 transform_ = la::identity;
   CrossSection(std::shared_ptr<const PathImpl> paths);
diff --git a/include/manifold/manifold.h b/include/manifold/manifold.h
index 7015e8a..bc3a654 100644
--- a/include/manifold/manifold.h
+++ b/include/manifold/manifold.h
@@ -16,6 +16,7 @@
 #include <cstdint>  // uint32_t, uint64_t
 #include <functional>
 #include <memory>  // needed for shared_ptr
+#include <mutex>   // needed for once_flag
 
 #include "manifold/common.h"
 #include "manifold/vec_view.h"
@@ -530,6 +531,8 @@ class Manifold {
   Manifold(std::shared_ptr<CsgNode> pNode_);
   Manifold(std::shared_ptr<Impl> pImpl_);
   static Manifold Invalid();
+  mutable std::shared_ptr<std::once_flag> pNodeOnce_ =
+      std::make_shared<std::once_flag>();
   mutable std::shared_ptr<CsgNode> pNode_;
 
   CsgLeafNode& GetCsgLeafNode() const;
diff --git a/src/cross_section/cross_section.cpp b/src/cross_section/cross_section.cpp
index 578db25..f9fa801 100644
--- a/src/cross_section/cross_section.cpp
+++ b/src/cross_section/cross_section.cpp
@@ -234,6 +234,7 @@ CrossSection::CrossSection(const CrossSection& other) {
 
 CrossSection& CrossSection::operator=(const CrossSection& other) {
   if (this != &other) {
+    pathsOnce_ = std::make_shared<std::once_flag>();
     paths_ = other.paths_;
     transform_ = other.transform_;
   }
@@ -295,11 +296,12 @@ CrossSection::CrossSection(const Rect& rect) {
 // All access to paths_ should be done through the GetPaths() method, which
 // applies the accumulated transform_
 std::shared_ptr<const PathImpl> CrossSection::GetPaths() const {
-  if (transform_ == mat2x3(la::identity)) {
-    return paths_;
-  }
-  paths_ = shared_paths(::transform(paths_->paths_, transform_));
-  transform_ = mat2x3(la::identity);
+  std::call_once(*pathsOnce_, [this]() {
+    if (transform_ != mat2x3(la::identity)) {
+      paths_ = shared_paths(::transform(paths_->paths_, transform_));
+      transform_ = mat2x3(la::identity);
+    }
+  });
   return paths_;
 }
 
diff --git a/src/manifold.cpp b/src/manifold.cpp
index 56c2655..2fb18e7 100644
--- a/src/manifold.cpp
+++ b/src/manifold.cpp
@@ -137,15 +137,18 @@ Manifold Manifold::Invalid() {
 
 Manifold& Manifold::operator=(const Manifold& other) {
   if (this != &other) {
+    pNodeOnce_ = std::make_shared<std::once_flag>();
     pNode_ = other.pNode_;
   }
   return *this;
 }
 
 CsgLeafNode& Manifold::GetCsgLeafNode() const {
-  if (pNode_->GetNodeType() != CsgNodeType::Leaf) {
-    pNode_ = pNode_->ToLeafNode();
-  }
+  std::call_once(*pNodeOnce_, [this]() {
+    if (pNode_->GetNodeType() != CsgNodeType::Leaf) {
+      pNode_ = pNode_->ToLeafNode();
+    }
+  });
   return *std::static_pointer_cast<CsgLeafNode>(pNode_);
 }
 
