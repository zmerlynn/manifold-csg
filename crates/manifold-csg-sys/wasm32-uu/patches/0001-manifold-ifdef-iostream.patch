@@ -1075,6 +1076,7 @@ void manifold_meshgl64_write_obj(ManifoldMeshGL64* mesh,
   WriteOBJ(ss, *m);
   callback(ss.str().data(), args);
 }
+#endif  // !MANIFOLD_NO_IOSTREAM
 
 #ifdef __cplusplus
 }
